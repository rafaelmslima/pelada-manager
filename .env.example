# Copie este arquivo para .env local e ajuste os valores
# Exemplo: cp .env.example .env

# Banco de dados
# Local (SQLite):
DATABASE_URL=sqlite:///./pelada_manager.db

# ProduńŃo (PostgreSQL/Railway), exemplo:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB_NAME

# Seguranńa de cookie de sessŃo
# false para HTTP local, true para HTTPS (Railway)
SESSION_COOKIE_SECURE=false

# Codigo secreto para reset administrativo de senha
PASSWORD_RESET_ADMIN_SECRET=troque-este-codigo
